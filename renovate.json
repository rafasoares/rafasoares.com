{
  "extends": [
    "config:best-practices",
    "config:js-app",
    "github>nuxt/renovate-config-nuxt",
    ":preserveSemverRanges"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "matchDepTypes": [
        "resolutions"
      ],
      "enabled": false
    },
    {
      "matchDepTypes": [
        "devDependencies",
        "dev-dependencies",
        "dev"
      ],
      "automerge": true
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ]
}
